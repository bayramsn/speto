generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  SUPPORT
  VENDOR
}

enum StorefrontType {
  RESTAURANT
  MARKET
  OTHER_BUSINESS
}

enum FulfillmentMode {
  PICKUP
}

enum OrderStatus {
  CREATED
  ACCEPTED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum InventoryMovementType {
  SALE
  MANUAL_ADJUSTMENT
  RESTOCK
  POS_SYNC
  RESERVATION
  RELEASE
}

enum IntegrationType {
  POS
  ERP
}

enum IntegrationHealth {
  HEALTHY
  WARNING
  FAILED
}

enum SyncRunStatus {
  IDLE
  RUNNING
  SUCCESS
  FAILED
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

enum CampaignKind {
  HAPPY_HOUR
  DISCOUNT
  CLEARANCE
  BUNDLE
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum VendorApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum AdminNotificationStatus {
  DRAFT
  SCHEDULED
  SENT
}

enum AdminNotificationAudience {
  ALL_USERS
  ALL_BUSINESSES
  ALL_VENDORS
  CUSTOM
}

enum ContentBlockType {
  HOME_HERO
  QUICK_FILTER
  DISCOVERY_FILTER
}

model User {
  id                         String              @id @default(cuid())
  email                      String              @unique
  passwordHash               String              @map("password")
  displayName                String
  phone                      String?
  role                       Role                @default(CUSTOMER)
  vendorId                   String?
  isSuspended                Boolean             @default(false)
  suspendedReason            String?
  isBanned                   Boolean             @default(false)
  bannedReason               String?
  lastLoginAt                DateTime?
  studentVerifiedAt          DateTime?
  termsAcceptedAt            DateTime?
  privacyAcceptedAt          DateTime?
  marketingOptIn             Boolean             @default(false)
  opsNotificationPreferences Json?
  notificationsEnabled       Boolean             @default(true)
  avatarUrl                  String?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  favorites                  Favorite[]
  orderRatings               OrderRating[]
  addresses                  SavedPlace[]
  orders                     Order[]
  paymentMethods             PaymentMethod[]
  tickets                    Ticket[]
  walletEntries              WalletLedgerEntry[]
  supportTickets             SupportTicket[]
  assignedSupportTickets     SupportTicket[]      @relation("AssignedSupportTickets")
  supportTicketMessages      SupportTicketMessage[]
  refreshSessions            RefreshSession[]
  adminRefreshSessions       AdminRefreshSession[]
  adminAuditLogs             AdminAuditLog[]
  createdNotifications       AdminNotification[]
  updatedSettings            PlatformSetting[]
  vendor                     Vendor?             @relation("VendorOperators", fields: [vendorId], references: [id])
}

model SavedPlace {
  id        String   @id @default(cuid())
  userId    String
  label     String
  address   String
  iconKey   String   @default("location")
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentMethod {
  id            String   @id @default(cuid())
  userId        String
  provider      String
  providerToken String   @unique
  brand         String
  last4         String
  expiryMonth   Int
  expiryYear    Int
  holderName    String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]
}

model Vendor {
  id                String                  @id @default(cuid())
  name              String
  slug              String                  @unique
  category          String
  city              String?
  district          String?
  taxNumber         String?
  taxOffice         String?
  storefrontId      String?                 @unique
  storefrontType    StorefrontType?
  subtitle          String?
  metaLabel         String?
  imageUrl          String?
  badge             String?
  rewardLabel       String?
  promoLabel        String?
  ratingValue       Float?
  distanceLabel     String?
  etaMin            Int?
  etaMax            Int?
  workingHoursLabel String?
  workingDays       Json?
  reviewCountLabel  String?
  announcement      String?
  bundleTitle       String?
  bundleDescription String?
  bundlePrice       String?
  heroTitle         String?
  heroSubtitle      String?
  displayOrder      Int                     @default(0)
  studentFriendly   Boolean                 @default(false)
  isFeatured        Boolean                 @default(false)
  isActive          Boolean                 @default(true)
  approvalStatus    VendorApprovalStatus    @default(APPROVED)
  suspendedReason   String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @default(now()) @updatedAt
  pickupPoints      PickupPoint[]
  products          Product[]
  events            Event[]
  sections          CatalogSection[]
  highlights        VendorHighlight[]
  orders            Order[]
  inventory         InventoryStock[]
  movements         InventoryMovement[]
  integrations      IntegrationConnection[]
  bankAccounts      VendorBankAccount[]
  payouts           VendorPayout[]
  campaigns         VendorCampaign[]
  operators         User[]                  @relation("VendorOperators")
}

model PickupPoint {
  id        String   @id @default(cuid())
  vendorId  String
  label     String
  address   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orders    Order[]
}

model Product {
  id               String              @id @default(cuid())
  vendorId         String
  catalogSectionId String?
  title            String
  description      String?
  unitPrice        Decimal             @db.Decimal(10, 2)
  imageUrl         String?
  kind             String
  sku              String              @unique
  barcode          String?
  externalCode     String?
  displaySubtitle  String?
  displayBadge     String?
  displayOrder     Int                 @default(0)
  isFeatured       Boolean             @default(false)
  isVisibleInApp   Boolean             @default(true)
  searchKeywords   Json?
  legacyAliases    Json?
  trackStock       Boolean             @default(true)
  reorderLevel     Int                 @default(0)
  isArchived       Boolean             @default(false)
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  vendor           Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  catalogSection   CatalogSection?     @relation(fields: [catalogSectionId], references: [id], onDelete: SetNull)
  orderItems       OrderItem[]
  inventory        InventoryStock[]
  movements        InventoryMovement[]
}

model Event {
  id               String   @id @default(cuid())
  vendorId         String
  title            String
  venue            String
  district         String?
  imageUrl         String?
  startsAt         DateTime
  pointsCost       Int
  capacity         Int
  remainingCount   Int
  primaryTag       String?
  secondaryTag     String?
  description      String?
  organizer        String?
  participantLabel String?
  ticketCategory   String?
  locationTitle    String?
  locationSubtitle String?
  displayOrder     Int      @default(0)
  isFeatured       Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  vendor           Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  tickets          Ticket[]
}

model CatalogSection {
  id           String    @id @default(cuid())
  vendorId     String
  key          String
  label        String
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  vendor       Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([vendorId, key])
}

model VendorHighlight {
  id           String   @id @default(cuid())
  vendorId     String
  label        String
  iconKey      String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model ContentBlock {
  id           String           @id @default(cuid())
  type         ContentBlockType
  key          String           @unique
  title        String
  subtitle     String?
  badge        String?
  imageUrl     String?
  actionLabel  String?
  screen       String?
  iconKey      String?
  highlight    Boolean          @default(false)
  displayOrder Int              @default(0)
  isActive     Boolean          @default(true)
  payload      Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Order {
  id              String          @id @default(cuid())
  userId          String
  vendorId        String
  pickupPointId   String
  fulfillmentMode FulfillmentMode @default(PICKUP)
  status          OrderStatus     @default(CREATED)
  pickupCode      String
  etaLabel        String          @default("12 dk")
  subtotal        Decimal         @db.Decimal(10, 2)
  discountAmount  Decimal         @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal         @db.Decimal(10, 2)
  promoCode       String?
  paymentMethodId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  items           OrderItem[]
  ratings         OrderRating[]
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor          Vendor          @relation(fields: [vendorId], references: [id])
  pickupPoint     PickupPoint     @relation(fields: [pickupPointId], references: [id])
  paymentMethod   PaymentMethod?  @relation(fields: [paymentMethodId], references: [id])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  title     String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model WalletLedgerEntry {
  id          String   @id @default(cuid())
  userId      String
  delta       Int
  reason      String
  referenceId String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ticket {
  id         String    @id @default(cuid())
  userId     String
  eventId    String
  qrCode     String    @unique
  zone       String?
  seat       String?
  gate       String?
  redeemedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id              String                 @id @default(cuid())
  userId          String
  subject         String
  message         String
  channel         String
  status          SupportStatus          @default(OPEN)
  priority        SupportPriority        @default(NORMAL)
  assignedAdminId String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAdmin   User?                  @relation("AssignedSupportTickets", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  messages        SupportTicketMessage[]
}

model SupportTicketMessage {
  id          String        @id @default(cuid())
  ticketId    String
  authorId    String
  body        String
  isInternal  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  entityType String
  entityId   String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId])
}

model OrderRating {
  id        String   @id @default(cuid())
  userId    String
  orderId   String
  stars     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([userId, orderId])
}

model PasswordResetOtp {
  id         String    @id @default(cuid())
  email      String
  purpose    String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose, createdAt])
}

model RefreshSession {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AdminRefreshSession {
  id          String   @id @default(cuid())
  adminUserId String
  tokenHash   String   @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?
  adminUser   User     @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  adminUser   User     @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, createdAt])
  @@index([entityType, createdAt])
}

model PlatformSetting {
  id               String   @id @default(cuid())
  key              String   @unique
  value            Json
  updatedAt        DateTime @updatedAt
  updatedByAdminId String?
  updatedByAdmin   User?    @relation(fields: [updatedByAdminId], references: [id], onDelete: SetNull)
}

model AdminNotification {
  id               String                    @id @default(cuid())
  title            String
  body             String
  audience         AdminNotificationAudience @default(ALL_USERS)
  status           AdminNotificationStatus   @default(DRAFT)
  scheduledAt      DateTime?
  sentAt           DateTime?
  payload          Json?
  createdByAdminId String
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  createdByAdmin   User                      @relation(fields: [createdByAdminId], references: [id], onDelete: Cascade)
  deliveryLogs     AdminNotificationDeliveryLog[]

  @@index([status, createdAt])
}

model AdminNotificationDeliveryLog {
  id             String            @id @default(cuid())
  notificationId String
  provider       String
  status         String
  target         String?
  errorMessage   String?
  createdAt      DateTime          @default(now())
  notification   AdminNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId, createdAt])
}

model InventoryStock {
  id            String   @id @default(cuid())
  productId     String
  vendorId      String
  locationId    String
  locationLabel String
  onHand        Int      @default(0)
  reserved      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor        Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId])
}

model InventoryMovement {
  id               String                @id @default(cuid())
  productId        String
  vendorId         String
  type             InventoryMovementType
  quantityDelta    Int
  previousOnHand   Int
  nextOnHand       Int
  previousReserved Int
  nextReserved     Int
  orderId          String?
  note             String?
  createdAt        DateTime              @default(now())
  product          Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor           Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model IntegrationConnection {
  id          String               @id @default(cuid())
  vendorId    String
  name        String
  provider    String
  type        IntegrationType
  baseUrl     String
  locationId  String
  health      IntegrationHealth    @default(HEALTHY)
  skuMappings Json
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  vendor      Vendor               @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  syncRuns    IntegrationSyncRun[]
}

model IntegrationSyncRun {
  id             String                @id @default(cuid())
  connectionId   String
  status         SyncRunStatus         @default(IDLE)
  processedCount Int                   @default(0)
  errorMessage   String?
  startedAt      DateTime              @default(now())
  completedAt    DateTime?
  connection     IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model VendorBankAccount {
  id         String         @id @default(cuid())
  vendorId   String
  holderName String
  bankName   String
  iban       String
  isDefault  Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  vendor     Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  payouts    VendorPayout[]
}

model VendorPayout {
  id            String            @id @default(cuid())
  vendorId      String
  bankAccountId String
  amount        Decimal           @db.Decimal(10, 2)
  status        PayoutStatus      @default(PENDING)
  note          String?
  requestedAt   DateTime          @default(now())
  completedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  vendor        Vendor            @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  bankAccount   VendorBankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
}

model VendorCampaign {
  id              String         @id @default(cuid())
  vendorId        String
  kind            CampaignKind
  status          CampaignStatus @default(DRAFT)
  title           String
  description     String?
  startsAt        DateTime?
  endsAt          DateTime?
  scheduleLabel   String?
  badgeLabel      String?
  discountPercent Int?
  discountedPrice Decimal?       @db.Decimal(10, 2)
  productIds      Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  vendor          Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}
